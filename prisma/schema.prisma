generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String?
  email     String   @unique
  password  String?
  createdAt DateTime @default(now())

  goals        Goal[]
  transactions Transaction[]
}

model Goal {
  id            String    @id @default(cuid())
  title         String
  targetAmount  Float
  savedAmount   Float     @default(0)
  dailyTarget   Float
  deadline      DateTime?

  createdAt DateTime @default(now())

  userId String
  user   User @relation(fields: [userId], references: [id])

  savings Saving[]
}

model Saving {
  id        String   @id @default(cuid())
  amount    Float
  note      String?

  createdAt DateTime @default(now())

  goalId String
  goal   Goal @relation(fields: [goalId], references: [id])
}

model Transaction {
  id          String   @id @default(cuid())
  type        String
  category    String
  amount      Float
  description String?

  createdAt DateTime @default(now())

  userId String
  user   User @relation(fields: [userId], references: [id])
}